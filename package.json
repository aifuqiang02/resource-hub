{
  "name": "resource-hub",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev:api": "pnpm --filter @resource-hub/api dev",
    "dev:pc-web": "pnpm --filter @resource-hub/pc-web dev",
    "build": "pnpm -r --if-present build",
    "deploy:server": "node ./deploy/deploy.mjs",
    "lint": "pnpm -r --if-present lint",
    "remote:exec": "node ./deploy/remote-exec.mjs",
    "sync:nginx:tx07": "node ./deploy/sync-nginx-tx07.mjs",
    "test": "pnpm -r --if-present test:run && pnpm --filter @resource-hub/api test",
    "type-check": "pnpm -r --if-present type-check"
  },
  "dependencies": {
    "node-ssh": "^13.2.1"
  }
}
