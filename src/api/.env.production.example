# Copy to .env.production on the server
NODE_ENV=production
LOG_LEVEL=info
PORT=40251
LOG_DIR=./logs
LOG_RETENTION_DAYS=30
DATABASE_URL=postgresql://user:password@db-host:5432/resource_hub?schema=public
JWT_ACCESS_SECRET=replace-me-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-me-with-a-second-long-random-secret
JWT_ACCESS_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=7d
PAYMENT_NOTIFY_URL=https://your-api-domain
OPENAPI_SERVER_URL=https://your-api-domain
OPEN_PLATFORM_BASE_URL=https://open.tx07.cn
OPEN_PLATFORM_APP_ID=replace-with-open-platform-app-id
BITIFUL_S4_ENDPOINT=https://s3.bitiful.net
BITIFUL_S4_REGION=cn-east-1
BITIFUL_S4_BUCKET=my-oss
BITIFUL_S4_ACCESS_KEY=replace-with-your-access-key
BITIFUL_S4_SECRET_KEY=replace-with-your-secret-key
BITIFUL_S4_DEFAULT_PROJECT=resource-hub
BITIFUL_S4_PUBLIC_BASE_URL=https://your-bucket.s3.bitiful.net
